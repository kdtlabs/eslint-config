{
    "name": "@kdtlabs/eslint-config",
    "type": "module",
    "version": "0.0.6",
    "description": "Shared ESLint config for KDT Labs",
    "author": "Diep Dang <kdt310722@gmail.com>",
    "license": "MIT",
    "homepage": "https://github.com/kdtlabs/eslint-config",
    "repository": "github:kdtlabs/eslint-config",
    "bugs": {
        "url": "https://github.com/kdtlabs/eslint-config/issues",
        "email": "kdt310722@gmail.com"
    },
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "src"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "rimraf dist && bun run scripts/build.ts && tsc --project tsconfig.build.json",
        "release": "bun run build && bun run scripts/release.ts && bunx npm publish",
        "coverage": "bun test --coverage",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "typecheck": "tsc --noEmit",
        "up": "taze -I --group --force --peer --maturity-period 3",
        "preinstall": "only-allow bun && ([ -d .git ] && simple-git-hooks || true)"
    },
    "peerDependencies": {
        "eslint": "^10.2.0"
    },
    "dependencies": {
        "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
        "@eslint/js": "^10.0.1",
        "@eslint/markdown": "^8.0.2",
        "@stylistic/eslint-plugin": "^5.10.0",
        "eslint-plugin-antfu": "^3.2.3",
        "eslint-plugin-better-tailwindcss": "^4.5.0",
        "eslint-plugin-command": "^3.5.2",
        "eslint-plugin-import-lite": "^0.6.0",
        "eslint-plugin-jsdoc": "^63.0.0",
        "eslint-plugin-jsonc": "^3.2.0",
        "eslint-plugin-markdown-links": "^0.9.0",
        "eslint-plugin-markdown-preferences": "^0.41.1",
        "eslint-plugin-n": "^18.0.1",
        "eslint-plugin-perfectionist": "^5.9.0",
        "eslint-plugin-promise": "^7.3.0",
        "eslint-plugin-regexp": "^3.1.0",
        "eslint-plugin-security": "^4.0.0",
        "eslint-plugin-sonarjs": "^4.0.3",
        "eslint-plugin-toml": "^1.4.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "eslint-plugin-unused-imports": "^4.4.1",
        "eslint-plugin-vue": "^10.9.1",
        "eslint-plugin-yml": "^3.4.0",
        "globals": "^17.6.0",
        "local-pkg": "^1.2.1",
        "typescript-eslint": "^8.60.0",
        "vue-eslint-parser": "^10.4.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@types/bun": "^1.3.14",
        "@types/node": "^25.9.1",
        "changelogen": "^0.6.2",
        "eslint": "^10.2.0",
        "lint-staged": "^17.0.6",
        "only-allow": "^1.2.2",
        "rimraf": "^6.1.3",
        "simple-git-hooks": "^2.13.1",
        "taze": "^19.14.1",
        "typescript": "^6.0.3"
    },
    "simple-git-hooks": {
        "commit-msg": "bunx --no -- commitlint --edit ${1}",
        "pre-commit": "bunx lint-staged && bun run typecheck"
    },
    "lint-staged": {
        "*": "bun run lint:fix"
    },
    "commitlint": {
        "extends": "@commitlint/config-conventional"
    }
}
